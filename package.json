{
  "name": "mileboard-desktop",
  "version": "1.0.1",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.mile.board",
    "productName": "Mile Board Desktop",
    "directories": { "output": "dist" },
    "publish": null,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["ia32"]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true
    }
  }
}
